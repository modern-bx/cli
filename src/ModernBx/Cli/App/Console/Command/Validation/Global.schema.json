{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Общие определения JSON Schema для консольных команд",
  "$defs": {
    "stringOrNull": {
      "type": [
        "string",
        "null"
      ]
    },
    "scalarOrNull": {
      "type": [
        "string",
        "integer",
        "number",
        "boolean",
        "null"
      ]
    },
    "jsonValue": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "$include": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    }
  }
}
