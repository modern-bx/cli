{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Аргумент fields команд iblock:add/update",
  "description": "Допустимые поля JSON-объекта для CIBlock::Add/Update.",
  "$mixin": ["../../Validation/Global.schema.json"],
  "type": "object",
  "$include": false,
  "properties": {
    "ACTIVE": { "$ref": "#/$defs/string?" },
    "API_CODE": { "$ref": "#/$defs/string?" },
    "BIZPROC": { "$ref": "#/$defs/string?" },
    "CANONICAL_PAGE_URL": { "$ref": "#/$defs/string?" },
    "CODE": { "$ref": "#/$defs/string?" },
    "DESCRIPTION": { "$ref": "#/$defs/string?" },
    "DESCRIPTION_TYPE": { "$ref": "#/$defs/textType?" },
    "DETAIL_PAGE_URL": { "$ref": "#/$defs/string?" },
    "EDIT_FILE_AFTER": { "$ref": "#/$defs/string?" },
    "EDIT_FILE_BEFORE": { "$ref": "#/$defs/string?" },
    "ELEMENTS_NAME": { "$ref": "#/$defs/string?" },
    "ELEMENT_ADD": { "$ref": "#/$defs/string?" },
    "ELEMENT_DELETE": { "$ref": "#/$defs/string?" },
    "ELEMENT_EDIT": { "$ref": "#/$defs/string?" },
    "ELEMENT_NAME": { "$ref": "#/$defs/string?" },
    "FIELDS": { "$ref": "#/$defs/jsonValue" },
    "GROUP_ID": { "$ref": "#/$defs/jsonValue" },
    "IBLOCK_TYPE_ID": { "$ref": "#/$defs/string?" },
    "INDEX_ELEMENT": { "$ref": "#/$defs/string?" },
    "INDEX_SECTION": { "$ref": "#/$defs/string?" },
    "LID": { "$ref": "#/$defs/jsonValue" },
    "LIST_MODE": { "$ref": "#/$defs/string?" },
    "LIST_PAGE_URL": { "$ref": "#/$defs/string?" },
    "NAME": { "$ref": "#/$defs/string?" },
    "PICTURE": { "$ref": "#/$defs/fileValue" },
    "PROPERTY_INDEX": { "$ref": "#/$defs/string?" },
    "RIGHTS_MODE": { "$ref": "#/$defs/string?" },
    "RSS_ACTIVE": { "$ref": "#/$defs/string?" },
    "RSS_FILE_ACTIVE": { "$ref": "#/$defs/string?" },
    "RSS_FILE_DAYS": { "$ref": "#/$defs/numeric?" },
    "RSS_FILE_LIMIT": { "$ref": "#/$defs/numeric?" },
    "RSS_TTL": { "$ref": "#/$defs/numeric?" },
    "SECTION_CHOOSER": { "$ref": "#/$defs/string?" },
    "SECTION_PAGE_URL": { "$ref": "#/$defs/string?" },
    "SECTIONS_NAME": { "$ref": "#/$defs/string?" },
    "SECTION_ADD": { "$ref": "#/$defs/string?" },
    "SECTION_DELETE": { "$ref": "#/$defs/string?" },
    "SECTION_EDIT": { "$ref": "#/$defs/string?" },
    "SECTION_NAME": { "$ref": "#/$defs/string?" },
    "SITE_ID": { "$ref": "#/$defs/jsonValue" },
    "SORT": { "$ref": "#/$defs/numeric?" },
    "VERSION": { "$ref": "#/$defs/numeric?" },
    "WORKFLOW": { "$ref": "#/$defs/string?" },
    "XML_ID": { "$ref": "#/$defs/string?" }
  },
  "$defs": {
    "textType?": { "type": ["string", "null"], "enum": ["text", "html", null] },
    "fileValue": { "$ref": "#/$defs/jsonValue" }
  }
}
